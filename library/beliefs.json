  {
    "id": "lib:c001",
    "type": "implication",
    "kind": "state-machine",
    "domain": "library",
    "tags": ["circulation", "item-state"],
    "name": "item-status-lifecycle",
    "claim": "A circulating item moves through a fixed lifecycle of states: available, checked_out, on_hold, lost, and withdrawn.",
    "rules": [
      {"from": "available", "to": "checked_out", "requires": ["member_in_good_standing"]},
      {"from": "checked_out", "to": "available", "requires": ["no_active_hold"]},
      {"from": "checked_out", "to": "on_hold", "requires": ["active_hold"]},
      {"from": "checked_out", "to": "lost", "requires": ["overdue_30_days"]},
      {"from": "on_hold", "to": "checked_out", "requires": ["collected_by_holder"]},
      {"from": "on_hold", "to": "available", "requires": ["hold_expired"]},
      {"from": "available", "to": "withdrawn", "requires": ["deaccessioned"]}
    ],
    "invariants": [
      "An item is in exactly one state at any time.",
      "available is the only state from which a checkout can begin.",
      "A checked_out item has exactly one borrower.",
      "An on_hold item has at least one member in its hold queue.",
      "lost and withdrawn are terminal: they have no outgoing transitions."
    ],
    "contract": true,
    "subjects": [
      {"ref": "item-state/lifecycle", "type": "item-state"}
    ],
    "deps": ["lib:a003", "lib:a005", "lib:a006"],
    "status": "active",
    "created": "2026-01-08"
  },
